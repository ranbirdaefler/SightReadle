FROM python:3.11-slim

WORKDIR /app/scmpa

RUN apt-get update && apt-get install -y \
    ffmpeg \
    fluidsynth \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

COPY scmpa/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY scmpa/ .

EXPOSE 8001

CMD ["uvicorn", "server.scoring_service:app", "--host", "0.0.0.0", "--port", "8001"]
